# Frontend dev / build 變數。複製為 .env.local 並依環境調整。

# Backend 位置：next.config.mjs 將 /api/* rewrites 到此 URL。
# - 本機 backend：http://localhost:8000
# - GPU host backend：http://10.2.66.102:8000（Cobain 本機開發預設）
BACKEND_BASE_URL=http://localhost:8000

# Playwright e2e：dev server 監聽位置。
FRONTEND_BASE_URL=http://localhost:3000

# Playwright e2e：注入到 localStorage 'qwen-asr-token' 的測試 token。
# 預設用 bootstrap admin（CLAUDE.md 強制規範 #6 + admin scope wildcard per #28 同層 require_scope）。
E2E_API_TOKEN=please-change-me-to-strong-token

# 部署 profile。決定 sidebar 是否顯示 /finetune /correction submenu（spec §部署 Profile）。
# - client：甲方部署，僅顯示辨識 / 歷史 / 質檢 / 金鑰
# - vendor：乙方代管，顯示完整 nav
NEXT_PUBLIC_DEPLOYMENT_PROFILE=client
