# ============================================================
# Qwen3-ASR Phase 1 環境變數樣板
# 使用方式：cp .env.example .env，並依需要修改值
# ============================================================

# ----- 必填 -----
# API 認證金鑰（建議使用 32+ 字元高熵字串）
API_KEY=please-change-me-to-strong-token

# PostgreSQL 連線資訊
DB_PASSWORD=please-change-me
DATABASE_URL=postgresql+psycopg://qwasr:please-change-me@postgres:5432/qwen_asr
POSTGRES_USER=qwasr
POSTGRES_DB=qwen_asr
POSTGRES_PORT=5432

# 第三方授權確認（依規格 26 節，未設 true 將拒絕啟動）
THIRD_PARTY_LICENSE_ACK=true

# 部署環境
ENV=development
DEPLOYMENT_PROFILE=client

# ----- 模型與 vLLM -----
ASR_MODEL=Qwen/Qwen3-ASR-1.7B
VLLM_GPU_MEMORY_UTILIZATION=0.5
GPU_DEVICE=cuda:0
MAX_INFERENCE_BATCH=32
ASR_MAX_TOKENS=4096
ASR_REQUEST_TIMEOUT_SEC=1200
ASR_AUDIO_MAX_DURATION_SEC=1200

# 是否在容器內安裝音檔處理依賴（torch / torchaudio / soxr / soundfile / python-magic）
# M3 起需要設為 true；M1/M2 保持 false 降低映像大小（避免 CUDA stubs 約 2.5 GB）
INSTALL_AUDIO_DEPS=false

# 是否在容器內安裝 GPU 依賴（vLLM）
# CI 與本地開發設為 false；部署到 GPU 主機設為 true
INSTALL_GPU_DEPS=false

# 模型權重與音檔的 host volume 掛載點
MODEL_CACHE_DIR_HOST=./.data/models
AUDIO_STORAGE_DIR_HOST=./.data/audio

# ----- 音檔處理 -----
# VAD_ENABLED=true 時 lifespan 載入 fireredvad；需從 FireRedTeam GitHub
# (https://github.com/FireRedTeam/FireRedVAD) 取得 pretrained_models/FireRedVAD/VAD
# 內容（cmvn.ark + DetectModel 權重），掛入 VAD_MODEL_DIR（預設 /data/models/FireRedVAD）。
# 無模型目錄時 development 容忍降級為 vad_segments_count=0；production 直接 raise。
VAD_ENABLED=true
# VAD_MODEL_DIR=/data/models/FireRedVAD
MAX_UPLOAD_SIZE_MB=100
MAX_DECODE_SIZE_MB=500
SUPPORTED_AUDIO_FORMATS=wav,mp3,mp4,flac,aac,ogg,m4a

# ----- 佇列 -----
QUEUE_BATCH_MAX_SIZE=20
QUEUE_REALTIME_MAX_SIZE=50
QUEUE_REJECT_BEHAVIOR=reject

# ----- 可觀測性 -----
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----- 語者分離（vendor profile，client profile 可略過） -----
# HF_TOKEN：pyannote/speaker-diarization-3.1 模型授權下載必需
# 取得步驟：(1) 註冊 huggingface.co 帳號 (2) 至 pyannote/speaker-diarization-3.1
# 模型頁勾選 accept terms (3) https://huggingface.co/settings/tokens 建立
# read 權限 token。留空時 DiarizationService 跳過載入，僅於啟動時 warning。
DIARIZATION_ENABLED=true
DIARIZATION_BACKEND=pyannote
HF_TOKEN=

# ----- 安全與 CORS -----
# 多個 origin 用逗號分隔。瀏覽器若從 Linux GPU host IP 直接打 backend（例如
# 開 /docs OpenAPI），就需要把該 origin 加入；frontend 透過 Next.js dev rewrite
# 走 same-origin proxy，不會觸發 CORS。
CORS_ORIGINS=http://localhost:3000,http://10.2.66.102:3000
CORS_ALLOW_CREDENTIALS=false
OPENAPI_DOCS_ENABLED=true
# production 必須設為 true 以保護 API schema（依 T1.5 review I-2）
OPENAPI_DOCS_REQUIRE_AUTH=false

# ----- 服務 port -----
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ----- 前端容器 -----
# vendor：顯示 Fine-tune 子選單（校正/資料集/訓練/Hotword/YouTube）。
# client：僅顯示辨識 / 歷史 / 質檢 / 金鑰。
NEXT_PUBLIC_DEPLOYMENT_PROFILE=vendor
# frontend 容器內部如何打 backend（Docker DNS 解析 service 名）；override 時要
# 用 backend 可達的 hostname/port，不是 host 端的 localhost。
FRONTEND_BACKEND_BASE_URL=http://asr-backend:8000
